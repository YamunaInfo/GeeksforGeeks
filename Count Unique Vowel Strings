class Solution {
    public int vowelCount(String s) {
        int pro=1;
        int count=0;
        for(int i=0;i<s.length();i++)
        {
            char ch=s.charAt(i);
            if(ch=='a'||ch=='e'||ch=='i'||ch=='o'||ch=='u')
            {
                count++;
            }
        }
        for(int j=1;j<=count;j++)
        {
            pro*=j;
        }
        return pro;
    }
}
